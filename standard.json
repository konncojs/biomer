{
  "$schema": "https://biomejs.dev/schemas/2.3.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/dist",
      "!**/build",
      "!!**/node_modules",
      "!!**/.react-router",
      "!!**/.next",
      "!!**/.expo"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noAssignInExpressions": "off",
        "noVar": "error"
      },
      "correctness": {
        "noUnusedImports": {
          "level": "error",
          "fix": "safe",
          "options": {}
        }
      },
      "complexity": {
        "noImportantStyles": "off"
      },
      "performance": {
        "useTopLevelRegex": "error"
      },
      "style": {
        "useFragmentSyntax": "error",
        "noParameterAssign": "error",
        "noYodaExpression": "error",
        "useAtIndex": "warn",
        "useTemplate": "error",
        "noNonNullAssertion": "error",
        "useReactFunctionComponents": "error",
        "useShorthandFunctionType": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
