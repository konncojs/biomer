{
  "name": "@konnco/biomer",
  "version": "0.0.6",
  "description": "Standard Frontend rules for Konnco Studio using Biomejs.",
  "keywords": [
    "biome",
    "konnco",
    "frontend",
    "standard",
    "lint",
    "format",
    "rules"
  ],
  "homepage": "https://github.com/konncojs/biomer",
  "repository": {
    "url": "git+https://github.com/konncojs/biomer.git",
    "type": "git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "release": "release-it"
  },
  "author": "Konnco Studio <support@konnco.com> (konnco)",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "exports": {
    "./standard": "./standard.json"
  },
  "files": [
    "./standard.json"
  ],
  "devDependencies": {
    "release-it": "^19.2.4"
  },
  "release-it": {
    "npm": {
      "skipChecks": true
    },
    "github": {
      "release": true,
      "releaseName": "v${version}"
    },
    "git": {
      "tagName": "v${version}",
      "commitMessage": "v${version}",
      "tagAnnotation": "v${version}"
    }
  }
}
